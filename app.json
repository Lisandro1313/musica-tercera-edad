{
  "expo": {
    "name": "MUSIC+",
    "slug": "musica-tercera-edad",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0d1a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lisandro1313.musicplus",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Usamos el micrófono para buscar música por voz.",
        "NSMicrophoneUsageDescription": "Usamos el micrófono para buscar música por voz."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d0d1a"
      },
      "package": "com.lisandro1313.musicplus",
      "permissions": ["RECORD_AUDIO"],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
